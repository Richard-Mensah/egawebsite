# EGA Mentorship Website - Environment Variables
# Copy this file to .env and update with your actual values

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=change-me-to-a-secure-key

# Admin Configuration
ADMIN_PASSWORD=change-me-to-a-strong-password

# Database Configuration
DATABASE_PATH=ega_data.db

# Server Port
PORT=3000

# Email Configuration (for future use)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_SENDER=noreply@egamentorship.org

# Database URL (for PostgreSQL in production)
# DATABASE_URL=postgresql://user:password@localhost:5432/egadb

# Logging
# LOG_LEVEL=INFO
