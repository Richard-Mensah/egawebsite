{
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": ".",
  "functions": {
    "api/index.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(?!api)(.*\\.(?:html|css|js|json|jpg|jpeg|png|gif|svg|ico|woff|woff2|ttf|eot)?)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/home.html"
    }
  ],
  "env": {
    "FLASK_ENV": "production",
    "PYTHONUNBUFFERED": "1",
    "ADMIN_PASSWORD": "@ADMIN_PASSWORD"
  }
}
